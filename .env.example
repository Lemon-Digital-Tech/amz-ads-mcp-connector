# Amazon Ads MCP connector — credentials template.
# The setup wizard writes the REAL file to your per-user runtime home; you do not
# normally edit this by hand. This template documents the fields.

# Shared company LWA app (ask your team lead — same for everyone):
AMAZON_AD_API_CLIENT_ID="amzn1.application-oa2-client.XXXXXXXXXXXXXXXX"
AMAZON_AD_API_CLIENT_SECRET="amzn1.oa2-cs.v1.XXXXXXXXXXXXXXXX"

# Your PERSONAL refresh token (filled by the OAuth step — never share):
AMAZON_AD_API_REFRESH_TOKEN=""

# Region of your advertiser accounts: NA | EU | FE
AMAZON_AD_API_REGION="NA"

# Filled automatically after OAuth (comma-separated):
AMAZON_AD_API_PROFILE_IDS=""

# Optional: pin one profile (Fixed mode). Blank = Dynamic (LLM picks at runtime).
AMAZON_AD_API_FIXED_PROFILE_ID=""

# Local proxy port (change only on conflict):
AMAZON_ADS_MCP_PORT="9080"
